{
  "_comment": "Public install config. Edit this file in place for the current runtime.",
  "log_level": "INFO",
  "provider": "codex",
  "model": "gpt-5.4",
  "language": "en",
  "user_timezone": "Europe/Berlin",
  "update_check": true,
  "idle_timeout_minutes": 1440,
  "session_age_warning_hours": 12,
  "daily_reset_hour": 4,
  "daily_reset_enabled": false,
  "max_budget_usd": null,
  "max_turns": null,
  "max_session_messages": null,
  "permission_mode": "bypassPermissions",
  "cli_timeout": 600.0,
  "reasoning_effort": "high",
  "file_access": "all",
  "gemini_api_key": "null",
  "transport": "telegram",
  "transports": [
    "telegram"
  ],
  "telegram_token": "env:DUCTOR_TELEGRAM_TOKEN",
  "allowed_user_ids": [],
  "allowed_group_ids": [],
  "group_mention_only": false,
  "matrix": {
    "homeserver": "https://matrix-client.matrix.org",
    "user_id": "@your_bot:matrix.org",
    "password": "YOUR_MATRIX_PASSWORD",
    "access_token": "",
    "device_id": "",
    "allowed_rooms": [
      "!roomid1:matrix.org",
      "#your-room:matrix.org"
    ],
    "allowed_users": [
      "@you:matrix.org"
    ],
    "store_path": "matrix_store"
  },
  "streaming": {
    "enabled": true,
    "min_chars": 200,
    "max_chars": 4000,
    "idle_ms": 800,
    "edit_interval_seconds": 2.0,
    "max_edit_failures": 3,
    "append_mode": false,
    "sentence_break": true
  },
  "docker": {
    "enabled": false,
    "image_name": "ductor-sandbox",
    "container_name": "ductor-sandbox",
    "auto_build": true,
    "mount_host_cache": false,
    "mounts": [],
    "extras": []
  },
  "heartbeat": {
    "enabled": false,
    "interval_minutes": 30,
    "cooldown_minutes": 5,
    "quiet_start": 22,
    "quiet_end": 8,
    "prompt": "You are running as a background heartbeat check. Review the current workspace context:\n- Read memory_system/MAINMEMORY.md for user interests and personality\n- Check cron_tasks/ for active projects\n- Think about what might be useful, interesting, or fun for the user\n\nIf you have a creative idea, suggestion, interesting fact, or something the user might enjoy:\nReply with your message directly.\n\nIf nothing needs attention right now:\nReply exactly: HEARTBEAT_OK",
    "ack_token": "HEARTBEAT_OK",
    "group_targets": []
  },
  "cleanup": {
    "enabled": true,
    "media_files_days": 30,
    "output_to_user_days": 30,
    "api_files_days": 30,
    "check_hour": 3
  },
  "webhooks": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 8742,
    "token": "env:DUCTOR_WEBHOOK_TOKEN",
    "max_body_bytes": 262144,
    "rate_limit_per_minute": 30
  },
  "api": {
    "enabled": false,
    "host": "0.0.0.0",
    "port": 8741,
    "token": "env:DUCTOR_API_TOKEN",
    "chat_id": 123456789,
    "allow_public": false
  },
  "cli_parameters": {
    "claude": [
      "--verbose",
      "--chrome"
    ],
    "codex": [],
    "gemini": []
  },
  "image": {
    "max_dimension": 2000,
    "output_format": "webp",
    "quality": 85
  },
  "scene": {
    "seen_reaction": false,
    "technical_footer": false
  },
  "timeouts": {
    "normal": 600.0,
    "background": 1800.0,
    "subagent": 3600.0,
    "warning_intervals": [
      60.0,
      10.0
    ],
    "extend_on_activity": true,
    "activity_extension": 120.0,
    "max_extensions": 3
  },
  "tasks": {
    "enabled": true,
    "max_parallel": 3,
    "timeout_seconds": 3600.0
  },
  "interagent_port": 8799
}
